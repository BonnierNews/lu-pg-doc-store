{
  "name": "pg-doc-store",
  "description": "Opionated solution for storing documents as entities in postgres without an ORM-solution",
  "author": "Bonnier News",
  "contributors": [
    "Jens Carlén",
    "Jens-Peter Olsson",
    "Kristoffer Jansson",
    "Linda Andersson",
    "Max Olofsson",
    "Thorbjörn Karlström",
    "Linus Thiel",
    "Markus Ekholm",
    "Ivan Malmberg"
  ],
  "version": "10.1.1",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "test": "mocha --exit --reporter ${REPORTER:-spec} && eslint . --ext .js,.json --cache && knip --dependencies",
    "format": "prettier **/*.js --write && eslint . --fix",
    "depcheck": "knip --dependencies"
  },
  "repository": "https://github.com/BonnierNews/lu-pg-doc-store.git",
  "keywords": [
    "postgres",
    "postgresql",
    "simple",
    "entity",
    "store",
    "document",
    "orm"
  ],
  "license": "MIT",
  "main": "index.js",
  "dependencies": {
    "async": "^3.2.6",
    "exp-config": "^4.2.3",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "knip": "^5.85.0",
    "eslint": "^9.39.3",
    "@bonniernews/eslint-config": "^2.0.4",
    "eslint-import-resolver-exports": "^1.0.0-beta.5",
    "eslint-plugin-file-progress": "^3.0.2",
    "eslint-plugin-json": "^4.0.1",
    "mocha": "^11.7.5",
    "mocha-cakes-2": "^3.3.0",
    "prettier": "^3.8.1"
  },
  "overrides": {
    "mocha": {
      "diff@<8.0.3": "^8.0.3",
      "serialize-javascript@<7.0.3": "^7.0.3"
    },
    "minimatch@<10.2.4": "^10.2.4"
  }
}
